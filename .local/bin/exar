#!/bin/sh

file=
dest=
use_current_dir=n

extract() {
	if [ -z "$dest" ]; then
		dest="$file".dir
	fi
	case "$file" in
		*.tar*) tar   xvf "$file" -C "$dest" ;;
		*.zip)  unzip     "$file" -d "$dest" ;;
		*.rar)  unrar x   "$file"    "$dest" ;;
		*.7z)   7z    x   "$file"    "$dest" ;;
		*) echo "unsupport archive type"; exit 1 ;;
	esac
}

file_arg() {
	if [ -z "$file" ]; then
		file="$1"
	else
		if [ -z "$dest" ]; then
			echo "too many files"; exit 1
		fi
		dest="$1"
	fi
}

usage() {
	cat << EOF
usage: exar [OPTIONS] [FILE] [DEST]

options:
  -h: usage
EOF
	exit 1
}

until [ $# -eq 0 ]; do
	case "$1" in
		-c) use_current_dir=y ;;
		-h) usage ;;
		*) file_arg "$1" ;;
	esac
	shift
done

extract
