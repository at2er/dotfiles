#!/bin/sh

DEFAULT_BAT=BAT1
SUBSYS="/sys/class/power_supply"

usage() {
	cat << EOF
usage: getbat [-h] [BATx]
  -h: usage
EOF
}

[ "$1" == "-h" ] && usage

bat=${1:-$DEFAULT_BAT}
[ ! -d "$SUBSYS/$bat" ] && echo "AC Connected" && exit 0
cap=$(cat "$SUBSYS/$bat/capacity")
stat=""
case "$(cat "$SUBSYS/$bat/status")" in
	Charging)            stat="+" ;;
	Discharging)         stat="-" ;;
	"Not charging"|Full) stat="o" ;;
esac
echo "$cap%$stat"
